// ─────────────────────────────────────────────────────────────────
//  UI HELPERS
// ─────────────────────────────────────────────────────────────────
function fmt(num, dec = 2) {
    return new Intl.NumberFormat("th-TH", { minimumFractionDigits: dec, maximumFractionDigits: dec }).format(num);
}

function showLoading(msg) {
    document.getElementById("loading-overlay").classList.remove("hidden");
    document.getElementById("loading-sub").innerText = msg || "";
}
function hideLoading() {
    document.getElementById("loading-overlay").classList.add("hidden");
    const now = new Date().toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" });
    document.getElementById("last-updated-text").innerText = `อัปเดตล่าสุด: ${now}`;
}
function showError(detail) {
    const b = document.getElementById("error-banner");
    b.classList.remove("hidden");
    document.getElementById("error-detail").innerText = detail;
}
function hideError() {
    document.getElementById("error-banner").classList.add("hidden");
}
function setSyncOk() {
    const badge = document.getElementById("sync-badge");
    badge.classList.remove("border-red-700");
    badge.classList.add("border-slate-700");
    document.getElementById("sync-status-text").innerText = "เชื่อมต่อ Google Sheets";
    badge.querySelector(".pulse-dot").classList.replace("bg-red-400", "bg-emerald-400");
}
function setSyncError() {
    const badge = document.getElementById("sync-badge");
    badge.classList.add("border-red-700");
    document.getElementById("sync-status-text").innerText = "โหลดข้อมูลไม่สำเร็จ";
    badge.querySelector(".pulse-dot").classList.replace("bg-emerald-400", "bg-red-400");
}

// ─────────────────────────────────────────────────────────────────
//  FALLBACK DATA (ใช้เมื่อ Google Sheet โหลดไม่ได้)
// ─────────────────────────────────────────────────────────────────
const FALLBACK_DATA = [
