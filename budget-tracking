<!DOCTYPE html>
<html lang="th" class="h-full bg-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard ติดตามโครงการและงบประมาณกลุ่มจังหวัดภาคใต้ฝั่งอ่าวไทย</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #0b1329 0%, #1e293b 100%); }
        .card-shadow { box-shadow: 0 10px 25px -5px rgba(15,23,42,0.06), 0 8px 16px -6px rgba(15,23,42,0.04); }
        .border-premium { border-color: rgba(226,232,240,0.8); }

        /* ── Logo Upload Zone ── */
        #logo-drop-zone {
            cursor: pointer;
            transition: border-color .2s, background .2s;
        }
        #logo-drop-zone:hover { border-color: #f59e0b; background: rgba(245,158,11,.07); }
        #logo-drop-zone.drag-over { border-color: #f59e0b; background: rgba(245,158,11,.12); }

        /* ── Loading overlay ── */
        #loading-overlay {
            position: fixed; inset: 0; background: rgba(11,19,41,.88);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            z-index: 9999; transition: opacity .4s;
        }
        #loading-overlay.hidden { opacity: 0; pointer-events: none; }
        .spinner {
            width: 48px; height: 48px;
            border: 4px solid rgba(255,255,255,.15);
            border-top-color: #f59e0b;
            border-radius: 50%;
            animation: spin .8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Sync badge pulse ── */
        @keyframes pulse-dot { 0%,100% { opacity:1; } 50% { opacity:.3; } }
        .pulse-dot { animation: pulse-dot 1.5s ease-in-out infinite; }

        /* ── Row hover ── */
        tbody tr { transition: background .15s; }
    </style>
</head>
<body class="h-full text-slate-800 flex flex-col">

<!-- ════════════════════════════════════
     LOADING OVERLAY
════════════════════════════════════ -->
<div id="loading-overlay">
    <div class="spinner mb-4"></div>
    <p class="text-white font-semibold text-base">กำลังโหลดข้อมูลจาก Google Sheets…</p>
    <p class="text-slate-400 text-xs mt-1" id="loading-sub">กรุณารอสักครู่</p>
</div>

<!-- ════════════════════════════════════
     TOP HEADER
════════════════════════════════════ -->
<header class="gradient-bg text-white px-6 py-4 flex flex-col md:flex-row justify-between items-center border-b border-slate-800 shadow-xl gap-4">
    <div class="flex items-center space-x-4">

        <!-- ── Logo Area ── -->
        <div id="logo-container" class="relative shrink-0">
            <!--
                วิธีใส่โลโก้: วางไฟล์ชื่อ "logo.png" (หรือ .jpg/.svg)
                ไว้ในโฟลเดอร์เดียวกับ HTML บน GitHub แล้วเปลี่ยน
                LOGO_FILE ด้านล่างให้ตรงกับชื่อไฟล์
            -->
            <div id="logo-display"
                 class="w-16 h-16 rounded-full bg-slate-900 flex items-center justify-center border-2 border-amber-400 shadow-inner overflow-hidden">
                <!-- โลโก้จากไฟล์ (โหลดอัตโนมัติ) -->
                <img id="logo-img"
                     src="logo.png"
                     alt="โลโก้กลุ่มจังหวัดภาคใต้ฝั่งอ่าวไทย"
                     class="w-full h-full object-contain p-1"
                     onerror="this.classList.add('hidden'); document.getElementById('logo-placeholder').classList.remove('hidden');">
                <!-- Fallback SVG เมื่อไม่พบไฟล์ logo.png -->
                <svg id="logo-placeholder" class="hidden w-10 h-10 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9s2.015-9 4.5-9m0 0a9.003 9.003 0 018.716 6.747M12 3a9.003 9.003 0 00-8.716 6.747"/>
                </svg>
            </div>
        </div>

        <!-- ── Title ── -->
        <div>
            <div class="flex items-center space-x-2 flex-wrap gap-y-1">
                <span class="bg-amber-400 text-slate-950 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">ระบบราชการ 4.0</span>
                <h1 class="text-xl md:text-2xl font-black tracking-wide">Dashboard ติดตามงบประมาณโครงการ</h1>
            </div>
            <p class="text-xs text-slate-300 font-light mt-0.5">กลุ่มจังหวัดภาคใต้ฝั่งอ่าวไทย (สุราษฎร์ธานี · นครศรีธรรมราช · ชุมพร · พัทลุง · สงขลา)</p>
        </div>
    </div>

    <!-- ── Right: Sync Status + Update Time ── -->
    <div class="flex flex-col items-end gap-1.5">
        <span id="sync-badge"
              class="inline-flex items-center bg-slate-800/80 border border-slate-700 text-slate-300 text-xs px-3 py-1.5 rounded-xl font-medium gap-1.5">
            <span class="pulse-dot w-2 h-2 rounded-full bg-emerald-400"></span>
            <span id="sync-status-text">เชื่อมต่อ Google Sheets</span>
        </span>
        <p class="text-[10px] text-slate-400" id="last-updated-text">อัปเดตล่าสุด: —</p>
        <button onclick="fetchSheetData(true)"
                class="text-[10px] text-amber-400 hover:text-amber-300 transition-colors flex items-center gap-1">
            <i class="fa-solid fa-arrows-rotate"></i> รีเฟรชข้อมูล
        </button>
    </div>
</header>

<!-- ════════════════════════════════════
     MAIN CONTENT
════════════════════════════════════ -->
<main class="flex-1 p-4 md:p-6 space-y-6 max-w-[1600px] mx-auto w-full">

    <!-- ── FILTER BAR ── -->
    <div class="bg-white p-5 rounded-3xl card-shadow border border-premium flex flex-wrap gap-4 items-end">
        <div class="flex-1 min-w-[150px]">
            <label for="filter-year" class="block text-xs font-bold text-slate-500 mb-2">
                <i class="fa-solid fa-calendar-days text-indigo-600 mr-1.5"></i> ปีงบประมาณ
            </label>
            <select id="filter-year" onchange="applyFilters()"
                    class="w-full bg-slate-50 border border-slate-200 text-slate-700 py-2.5 px-3 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-medium">
                <option value="ALL">ทั้งหมด</option>
            </select>
        </div>
        <div class="flex-1 min-w-[180px]">
            <label for="filter-province" class="block text-xs font-bold text-slate-500 mb-2">
                <i class="fa-solid fa-map-location-dot text-indigo-600 mr-1.5"></i> จังหวัด (เจ้าภาพ)
            </label>
            <select id="filter-province" onchange="applyFilters()"
                    class="w-full bg-slate-50 border border-slate-200 text-slate-700 py-2.5 px-3 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-medium">
                <option value="ALL">ทั้งหมดทุกจังหวัด</option>
            </select>
        </div>
        <div class="flex-1 min-w-[200px]">
            <label for="search-agency" class="block text-xs font-bold text-slate-500 mb-2">
                <i class="fa-solid fa-magnifying-glass text-indigo-600 mr-1.5"></i> ค้นหาแผนงาน / หน่วยงาน
            </label>
            <div class="relative">
                <input type="text" id="search-agency" onkeyup="applyFilters()" placeholder="พิมพ์คำสำคัญ…"
                       class="w-full bg-slate-50 border border-slate-200 text-slate-700 py-2.5 pl-10 pr-4 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <i class="fa-solid fa-search absolute left-3.5 top-3.5 text-slate-400 text-xs"></i>
            </div>
        </div>
        <button onclick="resetFilters()"
                class="bg-slate-100 hover:bg-slate-200 text-slate-600 font-semibold py-2.5 px-5 rounded-xl text-sm transition-all flex items-center space-x-1.5 border border-slate-200">
            <i class="fa-solid fa-arrow-rotate-left text-xs"></i> <span>ล้างตัวกรอง</span>
        </button>
    </div>

    <!-- ── ERROR BANNER (hidden by default) ── -->
    <div id="error-banner" class="hidden bg-red-50 border border-red-200 text-red-700 px-5 py-4 rounded-2xl flex items-start gap-3">
        <i class="fa-solid fa-triangle-exclamation text-red-500 mt-0.5 shrink-0"></i>
        <div>
            <p class="font-bold text-sm">ไม่สามารถโหลดข้อมูลจาก Google Sheets ได้</p>
            <p class="text-xs mt-0.5" id="error-detail"></p>
            <p class="text-xs mt-1 text-red-600">💡 ตรวจสอบว่า Google Sheet ถูกตั้งเป็น <strong>"Anyone with the link can view"</strong> แล้ว และ Sheet ID ถูกต้อง</p>
        </div>
    </div>

    <!-- ── KPI CARDS ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4">
        <!-- Total Budget -->
        <div class="bg-white p-5 rounded-3xl card-shadow border border-premium flex flex-col justify-between relative overflow-hidden">
            <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">งบประมาณรวม</span>
                <div class="w-9 h-9 rounded-xl bg-sky-50 flex items-center justify-center text-sky-600">
                    <i class="fa-solid fa-wallet text-sm"></i>
                </div>
            </div>
            <div class="my-2">
                <div class="text-3xl font-black text-slate-800" id="kpi-budget">—</div>
                <span class="text-[11px] text-slate-400 font-medium">ล้านบาท</span>
            </div>
            <div class="text-xs font-bold text-emerald-600 flex items-center mt-2">
                <i class="fa-solid fa-arrow-trend-up mr-1"></i> เป้าหมายตาม พ.ร.บ.
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-sky-500"></div>
        </div>
        <!-- Disbursed -->
        <div class="bg-white p-5 rounded-3xl card-shadow border border-premium flex flex-col justify-between relative overflow-hidden">
            <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">ผลการเบิกจ่ายสะสม</span>
                <div class="w-9 h-9 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                    <i class="fa-solid fa-hand-holding-dollar text-sm"></i>
                </div>
            </div>
            <div class="my-2">
                <div class="text-3xl font-black text-slate-800" id="kpi-disbursed">—</div>
                <span class="text-[11px] text-slate-400 font-medium">ล้านบาท</span>
            </div>
            <div class="text-xs font-bold text-emerald-600 flex items-center mt-2" id="kpi-disbursed-change">
                <i class="fa-solid fa-arrow-trend-up mr-1"></i> +15.27% จากปีที่แล้ว
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-emerald-500"></div>
        </div>
        <!-- Spent -->
        <div class="bg-white p-5 rounded-3xl card-shadow border border-premium flex flex-col justify-between relative overflow-hidden">
            <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">ผลการใช้จ่ายจริงสะสม</span>
                <div class="w-9 h-9 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600">
                    <i class="fa-solid fa-receipt text-sm"></i>
                </div>
            </div>
            <div class="my-2">
                <div class="text-3xl font-black text-slate-800" id="kpi-spent">—</div>
                <span class="text-[11px] text-slate-400 font-medium">ล้านบาท</span>
            </div>
            <div class="text-xs font-bold text-emerald-600 flex items-center mt-2" id="kpi-spent-change">
                <i class="fa-solid fa-arrow-trend-up mr-1"></i> +13.27% จากปีที่แล้ว
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-indigo-500"></div>
        </div>
        <!-- % Disbursed Donut -->
        <div class="bg-white p-5 rounded-3xl card-shadow border border-premium flex flex-col justify-between items-center text-center relative overflow-hidden">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">ร้อยละการเบิกจ่าย</span>
            <div class="relative w-20 h-20 flex items-center justify-center">
                <canvas id="chart-pct-disbursed"></canvas>
                <div class="absolute"><span class="text-sm font-black text-slate-800" id="kpi-pct-disbursed-txt">0%</span></div>
            </div>
            <span class="text-[10px] text-slate-400 font-medium mt-2">เป้าหมายสะสม 100%</span>
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-sky-400"></div>
        </div>
        <!-- % Spent Donut -->
        <div class="bg-white p-5 rounded-3xl card-shadow border border-premium flex flex-col justify-between items-center text-center relative overflow-hidden">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">ร้อยละการใช้จ่ายจริง</span>
            <div class="relative w-20 h-20 flex items-center justify-center">
                <canvas id="chart-pct-spent"></canvas>
                <div class="absolute"><span class="text-sm font-black text-slate-800" id="kpi-pct-spent-txt">0%</span></div>
            </div>
            <span class="text-[10px] text-slate-400 font-medium mt-2">เป้าหมายสะสม 100%</span>
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-teal-500"></div>
        </div>
        <!-- Projects Count -->
        <div class="bg-white p-5 rounded-3xl card-shadow border border-premium flex flex-col justify-between relative overflow-hidden">
            <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">จำนวนโครงการ</span>
                <div class="w-9 h-9 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600">
                    <i class="fa-solid fa-list-check text-sm"></i>
                </div>
            </div>
            <div class="my-2">
                <div class="text-3xl font-black text-slate-800" id="kpi-projects">—</div>
                <span class="text-[11px] text-slate-400 font-medium">โครงการรวม</span>
            </div>
            <div class="text-xs font-bold text-slate-500 mt-2 flex items-center">
                <span class="inline-block w-2.5 h-2.5 rounded-full bg-sky-500 mr-1.5"></span>
                <span id="kpi-active-projects">ดำเนินการแล้ว 0 โครงการ</span>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-amber-500"></div>
        </div>
    </div>

    <!-- ── BAR CHART ── -->
    <div class="bg-white p-6 rounded-3xl card-shadow border border-premium">
        <div class="flex flex-col xl:flex-row justify-between items-start xl:items-center mb-6 gap-4">
            <div>
                <div class="flex items-center space-x-2">
                    <span class="inline-block bg-indigo-100 text-indigo-800 text-xs px-2.5 py-1 rounded-full font-bold uppercase">Vertical Executive Chart</span>
                    <h2 class="text-lg font-bold text-slate-800">เปรียบเทียบผลการดำเนินงานงบประมาณรายโครงการ</h2>
                </div>
                <p class="text-xs text-slate-400 mt-1">เรียงตามวงเงินงบประมาณสูงสุด · วางเมาส์บนแท่งกราฟเพื่อดูชื่อโครงการเต็ม</p>
            </div>
            <div class="flex flex-wrap items-center gap-4">
                <div class="flex items-center space-x-2 text-xs bg-slate-100 p-1.5 rounded-xl border border-slate-200">
                    <span class="text-slate-500 font-semibold pl-1">แกน X:</span>
                    <button id="btn-lbl-code" onclick="toggleLabelMode('code')"
                            class="px-2.5 py-1 rounded-lg font-bold transition-all bg-white text-slate-800 shadow-sm">รหัส P1, P2…</button>
                    <button id="btn-lbl-text" onclick="toggleLabelMode('text')"
                            class="px-2.5 py-1 rounded-lg font-bold transition-all text-slate-500 hover:text-slate-800">ย่อชื่อโครงการ</button>
                </div>
                <div class="flex flex-wrap gap-4 text-xs font-semibold bg-slate-50 p-3 rounded-xl border border-slate-100">
                    <div class="flex items-center space-x-1.5">
                        <span class="w-4 h-4 bg-slate-200 border border-slate-300 rounded inline-block"></span>
                        <span class="text-slate-600">งบประมาณรวม</span>
                    </div>
                    <div class="flex items-center space-x-1.5">
                        <span class="w-4 h-3 bg-indigo-500 rounded inline-block"></span>
                        <span class="text-slate-600">ใช้จ่ายจริง / PO</span>
                    </div>
                    <div class="flex items-center space-x-1.5">
                        <span class="w-4 h-1.5 bg-sky-400 rounded inline-block"></span>
                        <span class="text-slate-600">เบิกจ่ายสะสม</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="relative w-full bg-slate-50/50 p-4 rounded-2xl border border-dashed border-slate-200">
            <div class="absolute top-3 right-3 z-10 flex items-center space-x-2 text-xs">
                <span class="text-slate-500 font-bold">จำนวนโครงการบนกราฟ:</span>
                <select id="project-chart-limit" onchange="applyFilters()"
                        class="bg-white border border-slate-300 text-slate-700 py-1.5 px-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="5">Top 5</option>
                    <option value="10" selected>Top 10</option>
                    <option value="15">Top 15</option>
                    <option value="20">Top 20</option>
                    <option value="ALL">ทุกโครงการ</option>
                </select>
            </div>
            <div id="nested-chart-container" class="w-full mt-10" style="height:480px;">
                <canvas id="nested-project-chart"></canvas>
            </div>
        </div>
    </div>

    <!-- ── TABLE ── -->
    <div class="bg-white rounded-3xl card-shadow border border-premium overflow-hidden flex flex-col">
        <div class="px-6 py-5 border-b border-slate-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h2 class="text-md font-bold text-slate-800">รายละเอียดแผนงานและโครงการ</h2>
                <p class="text-xs text-slate-400">ใช้ตัวกรองด้านบนคัดกรองจังหวัด ปีงบประมาณ หรือพิมพ์คำค้นหา</p>
            </div>
            <button onclick="exportToCSV()"
                    class="bg-sky-50 hover:bg-sky-100 text-sky-700 border border-sky-100 font-bold py-2 px-4 rounded-xl text-xs transition-colors flex items-center gap-1.5">
                <i class="fa-solid fa-file-excel"></i> ส่งออกไฟล์ CSV
            </button>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-left text-sm">
                <thead class="bg-slate-50 text-slate-500 font-bold">
                    <tr>
                        <th class="py-3.5 px-4 text-center w-12">ลำดับ</th>
                        <th class="py-3.5 px-4 w-20">ปีงบฯ</th>
                        <th class="py-3.5 px-4 max-w-sm">โครงการ/แผนงาน</th>
                        <th class="py-3.5 px-4">หน่วยดำเนินการ</th>
                        <th class="py-3.5 px-4">เจ้าภาพจังหวัด</th>
                        <th class="py-3.5 px-4 text-right">งบประมาณ (บาท)</th>
                        <th class="py-3.5 px-4 text-right">เบิกจ่าย (บาท)</th>
                        <th class="py-3.5 px-4 text-right">ใช้จ่ายจริง (บาท)</th>
                        <th class="py-3.5 px-4 text-center w-28">อัตราเบิกจ่าย</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white" id="project-table-body"></tbody>
            </table>
        </div>
        <div class="bg-slate-50 px-6 py-4 border-t border-slate-100 text-xs text-slate-500 flex justify-between items-center flex-wrap gap-2">
            <span id="table-count-info">แสดง 0 รายการ</span>
            <span class="font-semibold text-indigo-700">
                รวมวงเงินงบประมาณที่คัดกรอง: <span id="table-total-sum">0.00</span> บาท
            </span>
        </div>
    </div>
</main>

<!-- ════════════════════════════════════
     FOOTER
════════════════════════════════════ -->
