<script>
// ─────────────────────────────────────────────────────────────────
//  CONFIGURATION  ← แก้ตรงนี้อย่างเดียวเมื่อต้องการเปลี่ยน Sheet
// ─────────────────────────────────────────────────────────────────
const SHEET_ID  = "159niMGJPfj585WFS9svBQ4M3yJome2t8fuvbx8nCURM";
const SHEET_GID = "0";   // gid ของชีตที่ต้องการ (ดูจาก URL #gid=...)
// Auto-refresh ทุก 5 นาที (ตั้งค่าเป็น 0 เพื่อปิด)
const AUTO_REFRESH_MS = 5 * 60 * 1000;

// ─────────────────────────────────────────────────────────────────
//  COLUMN MAP  ← แมปชื่อคอลัมน์ใน Google Sheet (ภาษาไทย)
//  เพิ่ม alias ได้ถ้า header ใน Sheet ต่างออกไป
// ─────────────────────────────────────────────────────────────────
const COL = {
    year:       ["ปีงบประมาณ", "ปี", "year"],
    name:       ["โครงการ", "ชื่อโครงการ", "แผนงาน", "ชื่อแผนงาน", "project"],
    agency:     ["หน่วยดำเนินการ", "หน่วยงาน", "ผู้รับผิดชอบ", "agency"],
    budget:     ["งบประมาณ", "วงเงินงบประมาณ", "วงเงิน", "งบฯ", "budget"],
    disbursed:  ["ผลการเบิกจ่ายสะสม", "เบิกจ่ายสะสม", "เบิกจ่าย", "disbursed"],
    spent:      ["ผลการใช้จ่ายจริงสะสม", "ใช้จ่ายจริงสะสม", "ใช้จ่ายจริง", "ใช้จ่าย", "spent", "po"],
    province:   ["เจ้าภาพจังหวัด", "จังหวัด", "จังหวัดเจ้าภาพ", "province"],
};

// ─────────────────────────────────────────────────────────────────
//  GLOBAL STATE
// ─────────────────────────────────────────────────────────────────
let RAW_DATABASE       = [];
let pctDisbursedChart  = null;
let pctSpentChart      = null;
let nestedChart        = null;
let currentLabelMode   = "code";

// ─────────────────────────────────────────────────────────────────
//  INIT
// ─────────────────────────────────────────────────────────────────
window.onload = async function () {
    buildDonutCharts();
    await fetchSheetData();
    if (AUTO_REFRESH_MS > 0) setInterval(() => fetchSheetData(), AUTO_REFRESH_MS);
};

// ─────────────────────────────────────────────────────────────────
//  FETCH GOOGLE SHEET DATA (CSV export)
// ─────────────────────────────────────────────────────────────────
async function fetchSheetData(manual = false) {
    showLoading(manual ? "รีเฟรชข้อมูล…" : "กำลังโหลดข้อมูลจาก Google Sheets…");
    hideError();

    // Google Sheets public CSV export URL
    const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${SHEET_GID}&cachebust=${Date.now()}`;

    try {
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const csv = await res.text();
        RAW_DATABASE = parseCSV(csv);

        if (RAW_DATABASE.length === 0) throw new Error("ไม่พบข้อมูลในชีท หรือ header ไม่ตรงกับที่กำหนด");

        updateFilterDropdowns();
        applyFilters();
        setSyncOk();
    } catch (err) {
        console.error("fetchSheetData error:", err);
        showError(err.message);
        setSyncError();
        // Fallback: ถ้ายังไม่มีข้อมูลเลย ใช้ข้อมูล hardcode เดิม
        if (RAW_DATABASE.length === 0) {
            RAW_DATABASE = FALLBACK_DATA;
            updateFilterDropdowns();
            applyFilters();
        }
    } finally {
        hideLoading();
    }
}

// ─────────────────────────────────────────────────────────────────
//  CSV PARSER  (รองรับ comma / tab, quoted fields, BOM)
// ─────────────────────────────────────────────────────────────────
function parseCSV(raw) {
    // Remove BOM
    const text = raw.replace(/^\uFEFF/, "").trim();
    const lines = text.split(/\r?\n/).filter(l => l.trim());
    if (lines.length < 2) return [];

    // Auto-detect delimiter
    const delim = lines[0].includes("\t") ? "\t" : ",";

    const headers = splitLine(lines[0], delim).map(h => h.trim().toLowerCase());

    // Map header positions for each field
    function findCol(aliases) {
        for (const alias of aliases) {
            const idx = headers.findIndex(h => h.includes(alias.toLowerCase()));
            if (idx !== -1) return idx;
        }
        return -1;
    }

    const idx = {
        year:     findCol(COL.year),
        name:     findCol(COL.name),
        agency:   findCol(COL.agency),
        budget:   findCol(COL.budget),
        disbursed:findCol(COL.disbursed),
        spent:    findCol(COL.spent),
        province: findCol(COL.province),
    };

    const result = [];
    lines.slice(1).forEach((line, i) => {
        const cols = splitLine(line, delim);
        const row = {
            id:        i + 1,
            year:      idx.year      >= 0 ? (cols[idx.year]     || "").trim() : "",
            name:      idx.name      >= 0 ? (cols[idx.name]     || "").trim() : `แถวที่ ${i+2}`,
            agency:    idx.agency    >= 0 ? (cols[idx.agency]   || "").trim() : "",
            budget:    idx.budget    >= 0 ? toNum(cols[idx.budget])   : 0,
            disbursed: idx.disbursed >= 0 ? toNum(cols[idx.disbursed]): 0,
            spent:     idx.spent     >= 0 ? toNum(cols[idx.spent])    : 0,
            province:  idx.province  >= 0 ? (cols[idx.province] || "").trim() : "",
        };
        if (row.name) result.push(row);
    });
    return result;
}

function splitLine(line, delim) {
    const result = []; let cur = ""; let inQ = false;
    for (let i = 0; i < line.length; i++) {
        const c = line[i];
        if (c === '"') { inQ = !inQ; continue; }
        if (c === delim && !inQ) { result.push(cur); cur = ""; continue; }
        cur += c;
    }
    result.push(cur);
    return result;
}

function toNum(v) {
    if (!v) return 0;
    const n = parseFloat(String(v).replace(/[,\s฿]/g, ""));
    return isNaN(n) ? 0 : n;
}

// ─────────────────────────────────────────────────────────────────
//  POPULATE FILTER DROPDOWNS DYNAMICALLY
// ─────────────────────────────────────────────────────────────────
function updateFilterDropdowns() {
    const years     = [...new Set(RAW_DATABASE.map(r => r.year).filter(Boolean))].sort();
    const provinces = [...new Set(RAW_DATABASE.map(r => r.province).filter(Boolean))].sort();

    const yearSel = document.getElementById("filter-year");
    const curYear = yearSel.value;
    yearSel.innerHTML = `<option value="ALL">ทั้งหมด</option>`;
    years.forEach(y => yearSel.insertAdjacentHTML("beforeend", `<option value="${y}">${y}</option>`));
    if ([...yearSel.options].some(o => o.value === curYear)) yearSel.value = curYear;

    const provSel = document.getElementById("filter-province");
    const curProv = provSel.value;
    provSel.innerHTML = `<option value="ALL">ทั้งหมดทุกจังหวัด</option>`;
    provinces.forEach(p => provSel.insertAdjacentHTML("beforeend", `<option value="${p}">${p}</option>`));
    if ([...provSel.options].some(o => o.value === curProv)) provSel.value = curProv;
}

// ─────────────────────────────────────────────────────────────────
//  FILTER & RENDER
// ─────────────────────────────────────────────────────────────────
function getFilteredDataset() {
    const year  = document.getElementById("filter-year").value;
    const prov  = document.getElementById("filter-province").value;
    const q     = document.getElementById("search-agency").value.toLowerCase().trim();
    return RAW_DATABASE.filter(r =>
        (year === "ALL" || r.year === year) &&
        (prov === "ALL" || r.province === prov) &&
        (q === "" || r.name.toLowerCase().includes(q) || r.agency.toLowerCase().includes(q))
    );
}

function applyFilters() {
    const data = getFilteredDataset();
    let totalBudget = 0, totalDisbursed = 0, totalSpent = 0, active = 0;
    data.forEach(r => {
        totalBudget    += r.budget;
        totalDisbursed += r.disbursed;
        totalSpent     += r.spent;
        if (r.disbursed > 0 || r.spent > 0) active++;
    });
    const pctD = totalBudget > 0 ? (totalDisbursed / totalBudget) * 100 : 0;
    const pctS = totalBudget > 0 ? (totalSpent     / totalBudget) * 100 : 0;

    // KPI
    document.getElementById("kpi-budget").innerText    = fmt(totalBudget    / 1e6);
    document.getElementById("kpi-disbursed").innerText = fmt(totalDisbursed / 1e6);
    document.getElementById("kpi-spent").innerText     = fmt(totalSpent     / 1e6);
    document.getElementById("kpi-pct-disbursed-txt").innerText = `${pctD.toFixed(2)}%`;
    document.getElementById("kpi-pct-spent-txt").innerText     = `${pctS.toFixed(2)}%`;
    document.getElementById("kpi-projects").innerText  = data.length;
    document.getElementById("kpi-active-projects").innerText = `ดำเนินการแล้ว ${active} โครงการ`;

    const yr = document.getElementById("filter-year").value;
    const dEl = document.getElementById("kpi-disbursed-change");
    const sEl = document.getElementById("kpi-spent-change");
    if (yr !== "ALL" && yr > "2568") {
        dEl.innerHTML = `<i class="fa-solid fa-hourglass-start mr-1 text-amber-500"></i> เริ่มไตรมาส 1-2`;
        sEl.innerHTML = `<i class="fa-solid fa-hourglass-start mr-1 text-amber-500"></i> เริ่มบันทึกข้อตกลง PO`;
    } else {
        dEl.innerHTML = `<i class="fa-solid fa-arrow-trend-up mr-1 text-emerald-500"></i> +15.27% จากปีที่แล้ว`;
        sEl.innerHTML = `<i class="fa-solid fa-arrow-trend-up mr-1 text-emerald-500"></i> +13.27% จากปีที่แล้ว`;
    }

    updateDonutProgress(pctD, pctS);
    renderBarChart(data);
    renderTable(data);
}

function resetFilters() {
    document.getElementById("filter-year").value     = "ALL";
    document.getElementById("filter-province").value = "ALL";
    document.getElementById("search-agency").value   = "";
    applyFilters();
}

// ─────────────────────────────────────────────────────────────────
//  CHARTS
// ─────────────────────────────────────────────────────────────────
function buildDonutCharts() {
    const mkDonut = (id, color) => new Chart(document.getElementById(id).getContext("2d"), {
        type: "doughnut",
        data: { datasets: [{ data: [0, 100], backgroundColor: [color, "#f1f5f9"], borderWidth: 0 }] },
        options: {
            cutout: "80%", responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } }
        }
    });
    pctDisbursedChart = mkDonut("chart-pct-disbursed", "#0ea5e9");
    pctSpentChart     = mkDonut("chart-pct-spent",     "#14b8a6");
}

function updateDonutProgress(pD, pS) {
    pctDisbursedChart.data.datasets[0].data = [pD, Math.max(0, 100 - pD)];
    pctDisbursedChart.update();
    pctSpentChart.data.datasets[0].data     = [pS, Math.max(0, 100 - pS)];
    pctSpentChart.update();
}

function toggleLabelMode(mode) {
    currentLabelMode = mode;
    document.getElementById("btn-lbl-code").className =
        mode === "code"
        ? "px-2.5 py-1 rounded-lg font-bold transition-all bg-white text-slate-800 shadow-sm"
        : "px-2.5 py-1 rounded-lg font-bold transition-all text-slate-500 hover:text-slate-800";
    document.getElementById("btn-lbl-text").className =
        mode === "text"
        ? "px-2.5 py-1 rounded-lg font-bold transition-all bg-white text-slate-800 shadow-sm"
        : "px-2.5 py-1 rounded-lg font-bold transition-all text-slate-500 hover:text-slate-800";
    applyFilters();
}

function renderBarChart(filteredData) {
    const ctx = document.getElementById("nested-project-chart").getContext("2d");
    if (nestedChart) nestedChart.destroy();
    if (!filteredData.length) return;

    const limit  = document.getElementById("project-chart-limit").value;
    let sorted   = [...filteredData].sort((a, b) => b.budget - a.budget);
    if (limit !== "ALL") sorted = sorted.slice(0, parseInt(limit));

    const labels    = sorted.map((p, i) =>
        currentLabelMode === "code"
        ? `P${i + 1}`
        : `P${i + 1}: ${p.name.replace("โครงการ", "").substring(0, 12)}…`
    );
    const fullNames = sorted.map(p => `[ปี ${p.year}] ${p.name}`);
    const mln       = v => (v / 1e6).toFixed(2);

    nestedChart = new Chart(ctx, {
        type: "bar",
        data: {
            labels,
            datasets: [
                { label: "วงเงินงบประมาณรวม",      data: sorted.map(p => mln(p.budget)),
                  backgroundColor: "rgba(226,232,240,0.9)", borderColor: "rgba(203,213,225,1)", borderWidth: 1.5,
                  barPercentage: 0.85, categoryPercentage: 0.75, order: 3 },
                { label: "ผลการใช้จ่ายจริง (Spent)", data: sorted.map(p => mln(p.spent)),
                  backgroundColor: "rgba(99,102,241,0.95)",
                  barPercentage: 0.55, categoryPercentage: 0.75, order: 2 },
                { label: "ผลการเบิกจ่าย (Disbursed)", data: sorted.map(p => mln(p.disbursed)),
                  backgroundColor: "rgba(56,189,248,1)",
                  barPercentage: 0.25, categoryPercentage: 0.75, order: 1 },
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false, grouped: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: "rgba(15,23,42,.95)",
                    titleFont: { size: 12, family: "Sarabun", weight: "bold" },
                    bodyFont:  { size: 11, family: "Sarabun" },
                    padding: 12, cornerRadius: 8,
                    callbacks: {
                        title: ctx => fullNames[ctx[0].dataIndex],
                        label: ctx => ` ${ctx.dataset.label}: ${ctx.raw} ล้านบาท`
                    }
                }
            },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 11, family: "Sarabun", weight: "bold" }, color: "#475569", maxRotation: 45, minRotation: 45 } },
                y: { beginAtZero: true, grid: { color: "#f1f5f9" },
                     ticks: { font: { size: 11, family: "Sarabun" } },
                     title: { display: true, text: "งบประมาณ (ล้านบาท)", font: { size: 11, family: "Sarabun", weight: "bold" } } }
            }
        }
    });
}

// ─────────────────────────────────────────────────────────────────
//  TABLE
// ─────────────────────────────────────────────────────────────────
function renderTable(dataset) {
    const tbody = document.getElementById("project-table-body");
    tbody.innerHTML = "";
    let sumBudget = 0;

    if (!dataset.length) {
        tbody.innerHTML = `<tr><td colspan="9" class="text-center py-10 text-slate-400">
            <i class="fa-solid fa-folder-open text-3xl mb-2 block"></i>
            ไม่พบข้อมูลตามเงื่อนไขที่กรอง</td></tr>`;
        document.getElementById("table-count-info").innerText  = "แสดง 0 รายการ";
        document.getElementById("table-total-sum").innerText   = "0.00";
        return;
    }

    dataset.forEach((item, i) => {
        sumBudget += item.budget;
        const pct = item.budget > 0 ? (item.disbursed / item.budget) * 100 : 0;
        let cls = "bg-slate-100 text-slate-600 border-slate-200";
        if (pct >= 90) cls = "bg-emerald-50 text-emerald-700 border-emerald-100";
        else if (pct >= 50) cls = "bg-sky-50 text-sky-700 border-sky-100";
        else if (pct > 0)   cls = "bg-amber-50 text-amber-700 border-amber-100";

        tbody.insertAdjacentHTML("beforeend", `
            <tr class="hover:bg-slate-50/70">
                <td class="py-3 px-4 text-center text-slate-400 font-bold">P${i + 1}</td>
                <td class="py-3 px-4"><span class="bg-slate-100 text-slate-600 px-2.5 py-1 rounded-lg text-xs font-bold">${item.year}</span></td>
                <td class="py-3 px-4 max-w-sm"><div class="font-semibold text-slate-800 line-clamp-2" title="${item.name}">${item.name}</div></td>
                <td class="py-3 px-4 text-xs text-slate-500">${item.agency}</td>
                <td class="py-3 px-4 text-xs font-semibold text-slate-600">${item.province}</td>
                <td class="py-3 px-4 text-right font-medium text-slate-700">${fmt(item.budget)}</td>
                <td class="py-3 px-4 text-right text-sky-600 font-bold">${item.disbursed > 0 ? fmt(item.disbursed) : "—"}</td>
                <td class="py-3 px-4 text-right text-indigo-600 font-bold">${item.spent > 0 ? fmt(item.spent) : "—"}</td>
                <td class="py-3 px-4 text-center">
                    <span class="inline-block px-2.5 py-1 rounded-full text-xs font-black border ${cls}">${pct.toFixed(1)}%</span>
                </td>
            </tr>`);
    });

    document.getElementById("table-count-info").innerText = `แสดงทั้งหมด ${dataset.length} รายการ`;
    document.getElementById("table-total-sum").innerText  = fmt(sumBudget);
}

// ─────────────────────────────────────────────────────────────────
//  EXPORT CSV
// ─────────────────────────────────────────────────────────────────
function exportToCSV() {
    const data = getFilteredDataset();
    if (!data.length) { alert("ไม่มีข้อมูลที่จะส่งออก"); return; }

    let csv = "\uFEFFลำดับ,ปีงบประมาณ,โครงการ/แผนงาน,หน่วยดำเนินการ,เจ้าภาพจังหวัด,งบประมาณ (บาท),เบิกจ่าย (บาท),ใช้จ่ายจริง (บาท),ร้อยละการเบิกจ่าย\n";
    data.forEach((r, i) => {
        const pct = r.budget > 0 ? ((r.disbursed / r.budget) * 100).toFixed(2) : 0;
        csv += `${i + 1},${r.year},"${r.name.replace(/"/g, '""')}","${r.agency.replace(/"/g, '""')}",${r.province},${r.budget},${r.disbursed},${r.spent},${pct}%\n`;
    });

    const a = Object.assign(document.createElement("a"), {
        href:     encodeURI("data:text/csv;charset=utf-8," + csv),
        download: `รายงานงบประมาณ_ภาคใต้ฝั่งอ่าวไทย_${new Date().toLocaleDateString("th-TH")}.csv`
    });
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

